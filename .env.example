DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=verify-full"

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# Used once to create or promote the first app admin.
BOOTSTRAP_ADMIN_EMAIL="you@example.com"

# Postmark support email workflow.
POSTMARK_SERVER_TOKEN=""
POSTMARK_MESSAGE_STREAM="outbound"
POSTMARK_INBOUND_WEBHOOK_SECRET=""
SUPPORT_FROM_EMAIL="support@psychdata.com"
SUPPORT_FROM_NAME="PsychData Support"
SUPPORT_APP_BASE_URL="http://localhost:3000"
# Comma-separated origins that may submit embedded support forms.
# Example: "https://surveys.psychdata.com,https://www.psychdata.com"
SUPPORT_ALLOWED_ORIGINS=""
# Set to "false" to disable automatic customer confirmation emails for new tickets.
SUPPORT_AUTO_REPLY_ENABLED="true"
# Optional. Required to verify Cloudflare Turnstile tokens for CAPTCHA-protected embedded forms.
TURNSTILE_SECRET_KEY=""

# S3 attachment storage.
ATTACHMENT_STORAGE_PROVIDER="s3"
ATTACHMENT_STORAGE_BUCKET=""
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# Local/disposable testing only. Enables the super-admin "delete all tickets" reset.
ENABLE_DANGEROUS_ADMIN_RESET="false"
